            line(x1="33", y1="127.5", x2="40", y2="95", stroke="#fbbf24", stroke-dasharray="2,2", stroke-width="1.5")
            line(x1="72", y1="105", x2="40", y2="95", stroke="#fbbf24", stroke-dasharray="2,2", stroke-width="1.5")
            circle(cx="40", cy="95", r="13", fill="#042f2e", stroke="#fbbf24", stroke-width="1.5")
            text(x="40", y="99", fill="#fbbf24", font-size="8", font-weight="bold", text-anchor="middle") 2:1🐑

            <!-- General Port 3:1 -->
            line(x1="228", y1="105", x2="255", y2="95", stroke="#fbbf24", stroke-dasharray="2,2", stroke-width="1.5")
            line(x1="267", y1="127.5", x2="255", y2="95", stroke="#fbbf24", stroke-dasharray="2,2", stroke-width="1.5")
            circle(cx="255", cy="95", r="13", fill="#042f2e", stroke="#fbbf24", stroke-width="1.5")
            text(x="255", y="99", fill="#fbbf24", font-size="8", font-weight="bold", text-anchor="middle") 3:1⛵

