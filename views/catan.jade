extends layout

block content
  style.
    .catan-container {
      display: grid;
      grid-template-columns: 1fr;
      gap: 30px;
      margin-bottom: 40px;
    }
    @media (min-width: 900px) {
      .catan-container {
        grid-template-columns: 1.2fr 1fr;
      }
    }
    
    /* Interactive Card Styles */
    .scenario-card {
      min-height: 440px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
    }
    
    .scenario-title {
      font-family: var(--font-heading);
      color: var(--color-gold);
      font-size: 1.5rem;
      margin-bottom: 15px;
      text-shadow: 0 0 8px rgba(251, 191, 36, 0.2);
    }
    
    .scenario-description {
      color: var(--text-secondary);
      font-size: 1rem;
      line-height: 1.6;
      margin-bottom: 25px;
    }
    
    .choice-list {
      display: flex;
      flex-direction: column;
      gap: 15px;
    }
    
    .choice-btn {
      background: rgba(16, 185, 129, 0.05);
      border: 1px solid rgba(16, 185, 129, 0.25);
      border-radius: 10px;
      padding: 16px 20px;
      text-align: left;
      color: var(--text-primary);
      cursor: pointer;
      font-family: var(--font-body);
      font-size: 0.95rem;
      transition: all 0.25s ease;
    }
    
    .choice-btn:hover {
      background: rgba(16, 185, 129, 0.15);
      border-color: var(--color-emerald-light);
      transform: translateX(5px);
      box-shadow: 0 0 10px rgba(16, 185, 129, 0.1);
    }
    
    /* SVG Board Styles */
    .board-card {
      padding: 25px;
    }
    .board-wrapper {
      display: flex;
      justify-content: center;
      align-items: center;
      background: rgba(0, 0, 0, 0.2);
      border-radius: 12px;
      padding: 10px;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .hex-poly {
      stroke-width: 1.5px;
      transition: fill 0.5s ease;
    }
    .settlement-node {
      fill: rgba(255, 255, 255, 0.15);
      stroke: rgba(255, 255, 255, 0.3);
      stroke-width: 1.5px;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .settlement-node.active-settlement {
      fill: var(--color-gold);
      stroke: #fff;
      stroke-width: 2px;
      r: 7;
      filter: drop-shadow(0 0 6px var(--color-gold));
    }
    .settlement-node.active-city {
      fill: #ef4444;
      stroke: var(--color-gold);
      stroke-width: 2.5px;
      r: 9;
      filter: drop-shadow(0 0 8px rgba(239, 68, 68, 0.9));
    }
    .road-line {
      stroke: rgba(255, 255, 255, 0.08);
      stroke-width: 4px;
      stroke-linecap: round;
      transition: all 0.4s ease;
    }
    .road-line.active-road {
      stroke: var(--color-emerald-light);
      stroke-width: 5px;
      filter: drop-shadow(0 0 5px var(--color-emerald-light));
    }
    .road-line.active-road-alt {
      stroke: var(--color-gold);
      stroke-width: 5px;
      filter: drop-shadow(0 0 5px var(--color-gold));
    }
    
    /* Bayesian Stats Panel */
    .bayesian-panel {
      display: flex;
      flex-direction: column;
      gap: 25px;
    }
    
    .stat-header {
      font-family: var(--font-heading);
      color: var(--text-primary);
      font-size: 1.3rem;
      border-bottom: 1px solid rgba(16, 185, 129, 0.2);
      padding-bottom: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .formula-badge {
      font-size: 0.8rem;
      background: rgba(251, 191, 36, 0.15);
      color: var(--color-gold);
      border: 1px solid rgba(251, 191, 36, 0.3);
      padding: 4px 10px;
      border-radius: 20px;
      font-family: monospace;
    }
    
    /* Strategy Bars */
    .strategy-item {
      margin-bottom: 15px;
    }
    
    .strategy-info {
      display: flex;
      justify-content: space-between;
      margin-bottom: 8px;
      font-size: 0.9rem;
    }
    
    .strategy-name {
      font-weight: 500;
      color: var(--text-primary);
    }
    
    .strategy-percentage {
      font-family: monospace;
      color: var(--color-emerald-light);
      font-weight: 700;
    }
    
    .bar-bg {
      background: rgba(255, 255, 255, 0.05);
      height: 10px;
      border-radius: 5px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .bar-fill {
      background: linear-gradient(90deg, var(--color-emerald-dark), var(--color-emerald-light));
      height: 100%;
      width: 33.33%;
      border-radius: 5px;
      transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 0 10px rgba(52, 211, 153, 0.4);
    }
    
    .bar-fill.gold {
      background: linear-gradient(90deg, #b45309, var(--color-gold));
      box-shadow: 0 0 10px rgba(251, 191, 36, 0.4);
    }
    
    /* Live Math Logs */
    .math-logs {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 10px;
      padding: 15px;
      font-family: monospace;
      font-size: 0.85rem;
      color: var(--text-secondary);
      border: 1px solid rgba(255, 255, 255, 0.05);
      max-height: 180px;
      overflow-y: auto;
    }
    
    .math-log-entry {
      margin-bottom: 8px;
      border-left: 2px solid var(--color-gold);
      padding-left: 10px;
    }
    
    .math-log-entry.header {
      border-left-color: var(--color-emerald-light);
      color: var(--text-primary);
      font-weight: bold;
    }
    
    /* Advisor Commentary */
    .advisor-bubble {
      background: rgba(16, 185, 129, 0.08);
      border-left: 4px solid var(--color-emerald-light);
      border-radius: 0 12px 12px 0;
      padding: 20px;
      color: var(--text-primary);
      font-style: italic;
      line-height: 1.5;
    }
    
    .advisor-bubble strong {
      font-family: var(--font-heading);
      color: var(--color-gold);
      font-style: normal;
      display: block;
      margin-bottom: 8px;
    }
    
    /* Interactive States */
    .stage-card {
      display: none;
    }
    .stage-card.active {
      display: flex;
      flex-direction: column;
      height: 100%;
    }
    
    .celebration-box {
      text-align: center;
      padding: 40px 20px;
    }
    
    .badge-icon {
      font-size: 4rem;
      margin-bottom: 20px;
      animation: pulse 2s infinite;
    }
    
    @keyframes pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.1); }
      100% { transform: scale(1); }
    }

  .catan-container
    <!-- LEFT: Scenario and Board -->
    div(style="display:flex; flex-direction:column; gap:30px;")
      .glass-card.scenario-card
        <!-- STAGE 1 -->
        .stage-card.active#stage-1
          div
            .scenario-title Step 1: Initial Settlement Placement
            .scenario-description The island of Catan is wide open. You must place your first settlement. Which intersection do you claim on the map?
          .choice-list
            button.choice-btn(onclick="makeChoice(0, 0)")
              strong Choice A: Settle on Ore-6, Wheat-8, and Sheep-5
              br
              span.text-muted High mineral deposits, strong potential for City development.
            button.choice-btn(onclick="makeChoice(0, 1)")
              strong Choice B: Settle on Wood-11, Brick-9, and Wheat-10
              br
              span.text-muted Abundant building materials, perfect for starting roads and expansions.
            button.choice-btn(onclick="makeChoice(0, 2)")
              strong Choice C: Settle on Wood-11, Sheep-4 + Coastal 2:1 Sheep Port
              br
              span.text-muted Coastal trade advantage, setting up specialized harbor exchanges.

        <!-- STAGE 2 -->
        .stage-card#stage-2
          div
            .scenario-title Step 2: Early Resource Trade
            .scenario-description You hold excess resources but need cards to progress. How do you trade?
          .choice-list
            button.choice-btn(onclick="makeChoice(1, 0)")
              strong Choice A: Trade 2 Wood + 1 Brick to get 1 Ore + 1 Wheat
              br
              span.text-muted Sacrificing builders to secure mineral cards for quick upgrades.
            button.choice-btn(onclick="makeChoice(1, 1)")
              strong Choice B: Trade 2 Sheep + 1 Ore to get 1 Brick + 1 Wood
              br
              span.text-muted Converting excess cards to lay down road connectors.
            button.choice-btn(onclick="makeChoice(1, 2)")
              strong Choice C: Build coastal Settlement and trade 2 Sheep directly to the 2:1 Port
              br
              span.text-muted Utilizing your harbor access to bypass trading with other players.

        <!-- STAGE 3 -->
        .stage-card#stage-3
          div
            .scenario-title Step 3: Mid-Game Construction
            .scenario-description Resources have accumulated in your hand. What is your construction priority?
          .choice-list
            button.choice-btn(onclick="makeChoice(2, 0)")
              strong Choice A: Upgrade your starting settlement to a City (3 Ore, 2 Wheat)
              br
              span.text-muted Double resource production from high-number hexes.
            button.choice-btn(onclick="makeChoice(2, 1)")
              strong Choice B: Build a Settlement on new clay/wood hex + 1 Road (1 Wood, 1 Brick, 1 Wheat, 1 Sheep + Road)
              br
              span.text-muted Spreading across Catan's map to secure more land.
            button.choice-btn(onclick="makeChoice(2, 2)")
              strong Choice C: Buy a Development Card (1 Ore, 1 Wheat, 1 Sheep)
              br
              span.text-muted Drawing from the codex to find Knights or secret Victory Points.

        <!-- STAGE 4 -->
        .stage-card#stage-4
          div
            .scenario-title Step 4: Final Victory Push
            .scenario-description You are at 8 Victory Points. How do you grab the final 2 points for the win?
          .choice-list
            button.choice-btn(onclick="makeChoice(3, 0)")
              strong Choice A: Build a City and buy Dev Cards to claim "Largest Army"
              br
              span.text-muted Relying on military knights and city upgrades.
            button.choice-btn(onclick="makeChoice(3, 1)")
              strong Choice B: Build 3 Roads to secure the "Longest Road" card
              br
              span.text-muted Locking down the road network to seal the victory.
            button.choice-btn(onclick="makeChoice(3, 2)")
              strong Choice C: Build Settlement on a general 3:1 Port to trade cards for points
              br
              span.text-muted Leveraging port dominance to convert final resources.

        <!-- COMPLETION STATE -->
        .stage-card#stage-complete
          .celebration-box
            .badge-icon 🏆
            .scenario-title Scenario Complete!
            .scenario-description You have guided your colony to victory! The Bayesian Advisor has successfully aligned its strategy with your choices.
            button.btn.btn-emerald(onclick="resetScenario()") Play Again

      .glass-card.board-card
        .scenario-title Runestone Board Map
        .board-wrapper
          svg#catan-board-svg(width="100%", height="260", viewBox="0 0 300 300")
            <!-- Defs for graphics -->
            defs
              filter#glow(x="-20%", y="-20%", width="140%", height="140%")
                feGaussianBlur(stdDeviation="3", result="blur")
                feComposite(in="SourceGraphic", in2="blur", operator="over")
            
            <!-- Harbor Lines & Docks -->
