            <!-- 2. NE (Wheat 8) -->
            polygon.hex-poly(points="228,105 189,127.5 150,105 150,60 189,37.5 228,60", fill="#78350f", stroke="#b45309")
            <!-- 3. West (Wood 11) -->
            polygon.hex-poly(points="111,172.5 72,195 33,172.5 33,127.5 72,105 111,127.5", fill="#14532d", stroke="#16a34a")
            <!-- 4. Center (Sheep 5) -->
            polygon.hex-poly(points="189,172.5 150,195 111,172.5 111,127.5 150,105 189,127.5", fill="#064e3b", stroke="#10b981")
            <!-- 5. East (Pasture 4) -->
            polygon.hex-poly(points="267,172.5 228,195 189,172.5 189,127.5 228,105 267,127.5", fill="#065f46", stroke="#34d399")
            <!-- 6. SW (Wheat 10) -->
            polygon.hex-poly(points="150,240 111,262.5 72,240 72,195 111,172.5 150,195", fill="#92400e", stroke="#f59e0b")
            <!-- 7. SE (Brick 9) -->
